# ElevenLabs (premium TTS)
ELEVENLABS_API_KEY=sk_xxx
ELEVENLABS_VOICE_ID=oJIuRMopN0sojGjwD6rQ

# Twilio
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_WHATSAPP_NUMBER=+14155238886
TU_CELULAR=+56912345678

# Base de datos
# Local: sqlite:///./filtro_llamadas.db
# Producción: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./filtro_llamadas.db

# JWT
JWT_SECRET=cambia-esto-por-algo-seguro-en-produccion
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# App
APP_PORT=8000
DEBUG=true
BASE_URL=http://localhost:8000

# Google Calendar OAuth2 (Pro/Premium)
